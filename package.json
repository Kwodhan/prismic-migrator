{
  "name": "prismic-migrator",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "front",
    "back"
  ],
  "supportedArchitectures": {
    "os": ["win32", "linux"],
    "cpu": ["x64"],
    "libc": ["glibc"]
  },
  "scripts": {
    "front": "npm run start -w front",
    "back": "npm run dev -w back",
    "dev": "concurrently \"npm run front\" \"npm run back\"",
    "typecheck": "tsc -p back/tsconfig.json && tsc -p front/tsconfig.app.json"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
